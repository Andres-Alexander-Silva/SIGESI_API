# =============================================
# SIGESI API - Variables de entorno (ejemplo)
# Copia este archivo como .env y completa los valores
# =============================================

# Django
SECRET_KEY=generaunaclavesecretaseguraaqui
DEBUG=True
# Para multiples hosts separar con coma: dominio1.com,dominio2.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ORIGIN_ALLOW_ALL=False
# Para multiples origenes separar con coma: https://app.dominio.com,https://admin.dominio.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_NAME=semilleros_db
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# Correo electronico (Gmail SMTP - opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# RESEND (Servicio de Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SIGESI <onboarding@resend.dev>

# Frontend
FRONTEND_URL=http://localhost:3000
